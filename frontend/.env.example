# Deriv OAuth credentials — get these from https://api.deriv.com (Register an app)
#
# CLIENT_ID  : OAuth2 client id (used for the PKCE 2.0 flow at auth.deriv.com/oauth2)
# APP_ID     : Legacy Deriv app id (used for the legacy token redirect + WebSocket)
# REDIRECT_URL : Optional. Defaults to the current origin if left blank.
#                Must exactly match a redirect URI registered for your app.

CLIENT_ID=
APP_ID=
REDIRECT_URL=

# Set TUNNEL=1 when serving the dev server through an https tunnel (ngrok /
# cloudflare) so Vite's hot-reload websocket connects over port 443.
TUNNEL=
